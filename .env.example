# ============================================================================
# Copy to .env.local and fill in. The chatbot runs on Groq's FREE tier.
# NEVER commit .env.local — .gitignore already excludes it.
# ============================================================================

# --- AI assistant (/api/chat) — Groq, free, no credit card -----------------
# 1. Sign up at https://console.groq.com  (Google/email, no card)
# 2. Create a key at https://console.groq.com/keys
LLM_API_KEY=gsk_...

# OpenAI-compatible — swap free providers by changing these three:
#   OpenRouter : https://openrouter.ai/api/v1   meta-llama/llama-3.3-70b-instruct:free
#   Cerebras   : https://api.cerebras.ai/v1     llama-3.3-70b
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Safety guardrail model. Set LLM_MODERATION_ENABLED=false to skip.
LLM_MODERATION_MODEL=openai/gpt-oss-safeguard-20b
LLM_MODERATION_ENABLED=true

# --- Contact form (/api/contact) — Resend free tier -------------------------
RESEND_API_KEY=re_...
CONTACT_TO_EMAIL=gervicorado@yahoo.com
